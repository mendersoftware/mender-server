{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':gitSignOff',
    ':rebaseStalePrs',
    ':semanticCommitTypeAll(chore)',
  ],
  reviewersFromCodeOwners: true,
  semanticCommits: 'enabled',
  semanticCommitScope: 'deps',
  schedule: [
    'after 10pm on Monday',
    'before 6am on Tuesday',
  ],
  prHourlyLimit: 2,
  prConcurrentLimit: 10,
  baseBranchPatterns: [
    'main',
    '4.0.x',
    '4.1.x',
  ],
  vulnerabilityAlerts: {
    enabled: true,
    schedule: [
      'at any time',
    ],
    automerge: false,
    automergeType: 'pr',
    labels: [
      'security',
    ],
  },
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/Dockerfile/',
      ],
      matchStrings: [
        'MENDER_ARTIFACT_VERSION=\\s*["\']?(?<currentValue>[\\d\\.]+)["\']?',
      ],
      depNameTemplate: 'mendersoftware/mender-artifact',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v?(?<version>.*)$',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/.gitlab-ci.yml/',
      ],
      matchStrings: [
        'DOCKER_VERSION:[\\s\\S]*?value:\\s*["\']?(?<currentValue>[\\d\\.]+)["\']?',
      ],
      depNameTemplate: 'docker',
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/frontend/pipeline.yml/',
      ],
      matchStrings: [
        'denoland/deno:(?<currentValue>[^\\s"\']+)',
      ],
      depNameTemplate: 'denoland/deno',
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/frontend/pipeline.yml/',
      ],
      matchStrings: [
        'NODE_IMAGE:[\\s\\S]*?value:\\s*["\']?(?<depName>[^:"\']+):(?<currentValue>[^"\']+)["\']?',
      ],
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
    },
  ],
  packageRules: [
    {
      matchManagers: [
        'gitlabci',
        'gitlabci-include',
      ],
      semanticCommitScope: '',
    },
    {
      matchManagers: [
        'gomod',
      ],
      groupName: 'golang-dependencies',
      groupSlug: 'golang-dependencies',
    },
    {
      matchManagers: [
        'dockerfile',
      ],
      groupName: 'docker-base-images',
      groupSlug: 'docker-base-images',
    },
    {
      matchManagers: [
        'docker-compose',
      ],
      matchFileNames: [
        '**/docker-compose+(.*.|.)+(yml|yaml)',
      ],
      groupName: 'docker-compose',
      groupSlug: 'docker-compose',
    },
    {
      matchManagers: [
        'pip_requirements',
        'pipenv',
        'poetry',
      ],
      groupName: 'python-dependencies',
      groupSlug: 'python-dependencies',
    },
    {
      matchManagers: [
        'npm',
      ],
      matchDepTypes: [
        'devDependencies',
      ],
      groupName: 'npm-dev-dependencies',
    },
    {
      matchManagers: [
        'npm',
      ],
      matchDepTypes: [
        'dependencies',
      ],
      groupName: 'npm-prod-dependencies',
      matchPackageNames: [
        '!/^@emotion/',
        '!/^@mui/',
      ],
    },
    {
      matchPackageNames: [
        '/^@emotion/',
        '/^@mui/',
      ],
      groupName: 'npm-mui',
    },
    {
      matchFileNames: [
        'frontend/tests/e2e_tests/package.json',
      ],
      matchPackageNames: [
        '/^@playwright/',
        '/^playwright/',
      ],
      groupName: 'playwright',
    },
    {
      matchFileNames: [
        'frontend/tests/e2e_tests/package.json',
      ],
      groupName: 'test-dependencies',
      matchPackageNames: [
        '!/^@playwright/',
        '!/^playwright/',
      ],
    },
    {
      matchManagers: [
        'git-submodules',
      ],
      enabled: false,
    },
    {
      matchBaseBranches: [
        '/^\\d+\\.\\d+\\.x$/',
      ],
      matchUpdateTypes: [
        'major',
      ],
      enabled: false,
    },
  ],
}
