  transition: background-color 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms,box-shadow 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms,border-color 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms;
}

.emotion-70::-moz-focus-inner {
  border-style: none;
}

.emotion-70.Mui-disabled {
  pointer-events: none;
  cursor: default;
}

@media print {
  .emotion-70 {
    -webkit-print-color-adjust: exact;
    color-adjust: exact;
  }
}

.emotion-70:hover {
  -webkit-text-decoration: none;
  text-decoration: none;
}

.emotion-70.Mui-disabled {
  color: rgba(0, 0, 0, 0.26);
}

.emotion-70::before {
  content: "\\200b";
  width: 0;
  overflow: hidden;
}

.emotion-70.Mui-disabled {
  border: 1px solid rgba(0, 0, 0, 0.12);
}

@media (hover: hover) {
  .emotion-70:hover {
    --variant-containedBg: #c62828;
    --variant-textBg: rgba(211, 47, 47, 0.04);
    --variant-outlinedBorder: #d32f2f;
    --variant-outlinedBg: rgba(211, 47, 47, 0.04);
  }
}

.emotion-70.MuiButton-loading {
  color: transparent;
}

