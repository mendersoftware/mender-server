    "vm-browserify": "1.1.2",
    "webpack-license-plugin": "^4.5.1",
    "yarn": "1.22.22"
  },
  "overrides": {
    "tss-react": {
      "@mui/material": "$@mui/material"
    }
  },
  "browserslist": [
    ">0.2%",
    "last 5 versions",
    "not dead",
    "not op_mini all"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mendersoftware/gui.git"
  },
  "type": "module",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "post-commit": "sh ${MENDER_TESTING}/check_commits.sh"
    }
  },
  "scripts": {
    "build": "rspack --mode production",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "format:check": "prettier --check \"src/js/**/*.{js,ts,jsx,tsx,less}\"",
    "serve": "rspack serve --mode development",
    "serve:mocked": "MOCKS=true rspack serve --mode development",
    "test": "vitest --dir src/js",
    "test-types": "tsc --project ./tsconfig-test.json",
    "watch": "rspack --watch --mode development",
    "yalc:init": "yalc add @northern.tech/store @northern.tech/themes @northern.tech/utils @northern.tech/testing",
    "yalc:clean": "yalc remove --all && npm install"
  },
  "author": "Northern.tech AS",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://northerntech.atlassian.net/projects/MEN"
  },
  "homepage": "https://mender.io/",
  "lint-staged": {
    "*.js": "eslint --cache --fix"
  }
}
