    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "jsdom-worker": "0.3.0",
    "lint-staged": "16.4.0",
    "msw": "2.13.4",
    "path-browserify": "^1.0.1",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.3",
